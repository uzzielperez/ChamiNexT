        "label": "Ship quality signal"
      },
      "branches": [
        {
          "id": "foundations",
          "label": "Foundations",
          "description": "How you think before you code",
          "leaves": [
            {
              "id": "decomposition",
              "label": "Problem decomposition",
              "fundamentals": [
                "clarify constraints before coding",
                "break ambiguous problems into subproblems",
                "name edge cases explicitly"
              ],
              "domains": ["arrays", "strings", "trees"]
            }
          ]
        },
        {
          "id": "core-domains",
          "label": "Core domains",
          "description": "Data structures and algorithms in practice",
          "leaves": [
            {
              "id": "arrays",
              "label": "Arrays & two pointers",
              "fundamentals": [
                "invariants for sliding windows",
                "trade memory for time deliberately",
                "state complexity before optimizing"
              ],
              "domains": ["arrays"]
            },
            {
              "id": "trees",
              "label": "Trees & graphs",
              "fundamentals": [
                "pick traversal for the question",
                "handle null and empty base cases",
                "recursive vs iterative trade-offs"
              ],
              "domains": ["trees"]
            },
            {
              "id": "strings",
              "label": "Strings & parsing",
              "fundamentals": [
                "character-level vs substring reasoning",
                "hash maps for frequency and grouping",
                "watch off-by-one on indices"
              ],
              "domains": ["strings"]
            }
          ]
        },
        {
          "id": "production",
          "label": "Production",
          "description": "Debug and design at scale",
          "leaves": [
            {
              "id": "debugging",
              "label": "Debugging under pressure",
              "fundamentals": [
                "reproduce before fixing",
                "isolate failure scope",
                "explain root cause not symptom"
              ],
              "domains": ["debugging"]
            },
            {
              "id": "system-design-swe",
              "label": "System design",
              "fundamentals": [
                "capacity and latency estimates",
                "bottleneck identification",
                "consistency vs availability trade-offs"
              ],
              "domains": ["system-design"]
            }
          ]
        },
        {
          "id": "ai-era",
          "label": "AI era",
          "description": "Working with AI as a teammate",
          "leaves": [
            {
              "id": "ai-collaboration-swe",
              "label": "AI-assisted delivery",
              "fundamentals": [
                "verify AI output instead of trusting it",
                "explain decisions AI did not make for you",
                "recover when AI output is wrong"
              ],
              "domains": ["debugging", "system-design"]
            }
          ]
        }
      ]
    },
