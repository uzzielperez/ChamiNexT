          "label": "Foundations",
          "description": "How you think before you code",
          "leaves": [
            {
              "id": "decomposition",
              "label": "Problem decomposition",
              "fundamentals": [
                "clarify constraints before coding",
                "break ambiguous problems into subproblems",
                "name edge cases explicitly"
              ],
              "domains": ["arrays", "strings", "trees"]
            }
          ]
        },
        {
          "id": "core-domains",
          "label": "Core domains",
          "description": "Data structures and algorithms in practice",
          "leaves": [
            {
              "id": "arrays",
              "label": "Arrays & two pointers",
